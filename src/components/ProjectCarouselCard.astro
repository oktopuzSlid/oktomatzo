---
export interface Props {
  slug: string
  icon: string
  description: string
  href: string
}

const { slug, icon, description, href } = Astro.props as Props
---

<li class="carousel-card" data-slug={slug} data-description={description} data-href={href}>
  <div class="carousel-card-icon">
    {icon === 'smile' && (
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
        <circle cx="12" cy="12" r="10" />
        <path d="M8 14s1.5 2 4 2 4-2 4-2" />
        <line x1="9" y1="9" x2="9.01" y2="9" />
        <line x1="15" y1="9" x2="15.01" y2="9" />
      </svg>
    )}
    {icon === 'cube' && (
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
        <path d="M12 2L2 7l10 5 10-5-10-5z" />
        <path d="M2 17l10 5 10-5" />
        <path d="M2 12l10 5 10-5" />
      </svg>
    )}
  </div>
  <div class="carousel-card-title">{Astro.props.title}</div>
  <div class="carousel-card-category">{Astro.props.category}</div>
  <div class="carousel-card-arrow">Open</div>
</li>
