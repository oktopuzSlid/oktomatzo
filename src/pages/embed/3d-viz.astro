---
// Embed — no layout, just 3D canvas for iframe
---

<link rel="stylesheet" href="/css/style.css" />

<section>
  <div style="display:flex;flex-wrap:wrap;gap:6px;padding:10px 14px;">
    <button id="toggle-wireframe" class="btn btn-outline" style="padding:6px 14px; font-size:0.78rem;">Wireframe</button>
    <button id="toggle-rotation" class="btn btn-outline" style="padding:6px 14px; font-size:0.78rem;">Pause</button>
    <button id="save-scene" class="btn btn-outline" style="padding:6px 14px; font-size:0.78rem;">Save</button>
    <button id="upload-model" class="btn btn-outline" style="padding:6px 14px; font-size:0.78rem;">Upload</button>
    <input type="file" id="file-input" accept=".glb,.gltf,.obj,.stl" style="display:none">
  </div>

  <div id="saves-bar" style="display:none;margin-bottom:8px;gap:6px;flex-wrap:wrap;padding:0 14px;"></div>

  <div id="three-container" style="width:100%; height:calc(100vh - 100px); border:none;"></div>
</section>

<script type="importmap">
{
  "imports": {
    "three": "https://cdn.jsdelivr.net/npm/three@0.170/build/three.module.js",
    "three/addons/": "https://cdn.jsdelivr.net/npm/three@0.170/examples/jsm/"
  }
}
</script>
<script src="/js/projects/three-d-viz.js" type="module"></script>
