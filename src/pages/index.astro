---
import Base from '../layouts/Base.astro'
---

<Base title="Oktomatzo Host" description="A platform hosting interactive projects and experiments">
  <section class="hero">
    <div class="container hero-content">
      <h1 class="hero-title">Oktomatzo <span class="text-accent">Host</span></h1>
      <p class="hero-subtitle">
        A platform for interactive projects — 3D visualizers, data tools, and experiments.
      </p>
      <div class="hero-actions">
        <a href="/projects/" class="btn btn-primary">Browse Projects</a>
        <a href="/about/" class="btn btn-outline">About</a>
      </div>
    </div>
  </section>
</Base>
