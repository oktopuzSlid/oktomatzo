---
import Base from '../layouts/Base.astro'
---

<Base title="Login | Oktomatzo Host" description="Log in or sign up">
  <section class="page-section">
    <div class="container" style="max-width: 480px;">
      <h1 class="page-title" style="text-align: center;">Account</h1>
      <p class="page-description" style="text-align: center;">Sign up or log in to access all features.</p>

      <div style="margin-top: 32px;">
        <div style="display: flex; gap: 0; margin-bottom: 24px; border: 1px solid var(--border); border-radius: 8px; overflow: hidden;">
          <button id="tab-login" style="flex:1; padding:12px; background:rgba(59,130,246,0.1); color:var(--accent); border:none; cursor:pointer; font-family:inherit; font-size:0.9rem; font-weight:500;">Log In</button>
          <button id="tab-signup" style="flex:1; padding:12px; background:transparent; color:var(--text-muted); border:none; cursor:pointer; font-family:inherit; font-size:0.9rem;">Sign Up</button>
        </div>

        <form id="auth-form" novalidate style="display: flex; flex-direction: column; gap: 16px;">
          <div id="name-field" style="display: none; flex-direction: column; gap: 6px;">
            <label for="name" style="font-size: 0.85rem; color: var(--text-muted);">Name</label>
            <input type="text" id="name" style="padding:12px 16px; border-radius:8px; border:1px solid var(--border); background:rgba(255,255,255,0.03); color:var(--text-primary); font-family:inherit; font-size:0.9rem;">
          </div>
          <div style="display: flex; flex-direction: column; gap: 6px;">
            <label for="email" style="font-size: 0.85rem; color: var(--text-muted);">Email</label>
            <input type="email" id="email" required style="padding:12px 16px; border-radius:8px; border:1px solid var(--border); background:rgba(255,255,255,0.03); color:var(--text-primary); font-family:inherit; font-size:0.9rem;">
          </div>
          <div style="display: flex; flex-direction: column; gap: 6px;">
            <label for="password" style="font-size: 0.85rem; color: var(--text-muted);">Password</label>
            <input type="password" id="password" required minlength="8" style="padding:12px 16px; border-radius:8px; border:1px solid var(--border); background:rgba(255,255,255,0.03); color:var(--text-primary); font-family:inherit; font-size:0.9rem;">
          </div>
          <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 8px;">Log In</button>
        </form>

        <div id="auth-message" style="margin-top: 16px; padding: 12px; border-radius: 8px; display: none;"></div>

        <div id="logged-in" style="display: none; margin-top: 32px; text-align: center;">
          <div style="font-size: 3rem; margin-bottom: 16px;">&#10003;</div>
          <p style="color: var(--text-muted);">Logged in as <strong id="display-name" style="color: var(--text-primary);"></strong></p>
          <button id="logout-btn" class="btn btn-outline" style="margin-top: 16px;">Log Out</button>
        </div>
      </div>
    </div>
  </section>
</Base>

<script src="/js/login.js" defer></script>
