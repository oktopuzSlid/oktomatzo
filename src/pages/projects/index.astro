---
import Base from '../../layouts/Base.astro'
import ProjectCarouselCard from '../../components/ProjectCarouselCard.astro'
import { projects } from '../../lib/projects'
---

<Base title="Projects | Oktomatzo Host" description="Browse all interactive projects">
  <section class="page-section projects-page">
    <div class="container project-browser">
      <div class="page-header" style="margin-bottom: var(--space-md);">
        <h1 class="page-title">Projects</h1>
      </div>

      <div class="project-viewer">
        <iframe id="project-frame" src={projects[0].href} title="Project viewer"></iframe>
      </div>

      <div class="carousel-strip">
        <ul class="carousel-track" id="carousel-track">
          {projects.map(project => (
            <ProjectCarouselCard {...project} />
          ))}
        </ul>
      </div>
    </div>
  </section>
</Base>

<script src="/js/projects-carousel.js" defer></script>
