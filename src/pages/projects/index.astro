---
import Base from '../../layouts/Base.astro'
import { projects } from '../../lib/projects'
---

<Base title="Projects | Oktomatzo Host" description="Browse all interactive projects">
  <section class="projects-page">
    <div class="viewer-panel">
      <button class="arrow arrow-prev" id="arrow-prev" aria-label="Previous">&#8249;</button>
      <button class="arrow arrow-next" id="arrow-next" aria-label="Next">&#8250;</button>
      <iframe id="project-frame" src={projects[0].embedHref || projects[0].href} title="Project"></iframe>
    </div>

    <nav class="project-strip">
      <div class="strip-track" id="strip-track">
        {projects.map((p, i) => (
          <button class="strip-card" data-index={i} data-href={p.embedHref || p.href}>
            <span class="strip-icon">
              {p.icon === 'cube' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                  <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
                </svg>
              )}
              {p.icon === 'smile' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16">
                  <circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/>
                </svg>
              )}
            </span>
            <span class="strip-label">{p.title}</span>
          </button>
        ))}
      </div>
    </nav>
  </section>
</Base>

<script src="/js/projects-carousel.js" defer></script>
