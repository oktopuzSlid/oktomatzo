---
import Base from '../../layouts/Base.astro'
---

<Base title="3D Visualizer | Oktomatzo Host" description="Interactive 3D scene with Three.js">
  <section class="page-section" style="padding-bottom:0;">
    <div class="container">
      <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:16px;">
        <button id="toggle-wireframe" class="btn btn-outline" style="padding:8px 18px;">Wireframe</button>
        <button id="toggle-rotation" class="btn btn-outline" style="padding:8px 18px;">Pause</button>
        <button id="save-scene" class="btn btn-outline" style="padding:8px 18px;">Save Scene</button>
        <button id="upload-model" class="btn btn-outline" style="padding:8px 18px;">Upload Model</button>
        <input type="file" id="file-input" accept=".glb,.gltf,.obj,.stl" style="display:none">
      </div>

      <div id="saves-bar" style="display:none;margin-bottom:12px;gap:8px;flex-wrap:wrap;"></div>

      <div id="three-container" style="width:100%;height:480px;border-radius:12px;overflow:hidden;border:1px solid rgba(59,130,246,0.15);"></div>
    </div>
  </section>
</Base>

<script type="importmap">
{
  "imports": {
    "three": "https://cdn.jsdelivr.net/npm/three@0.170/build/three.module.js",
    "three/addons/": "https://cdn.jsdelivr.net/npm/three@0.170/examples/jsm/"
  }
}
</script>
<script src="/js/projects/three-d-viz.js" type="module" defer></script>
