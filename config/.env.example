# ── Server ──────────────────────────────────────────
HOST=0.0.0.0
PORT=8001

# ── CORS ────────────────────────────────────────────
# In production (Render), frontend and API are same origin.
# In development, allow the Astro dev server to call Python.
CORS_ORIGINS=http://localhost:4321,http://localhost:8001

# ── Authentication ──────────────────────────────────
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# ── Database (Supabase PostgreSQL) ──────────────────
# Format: postgresql://user:password@host:port/database
DATABASE_URL=

# ── Supabase Storage (for model file uploads) ───────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── Python Cache ────────────────────────────────────
# Redirects __pycache__ to a single folder
PYTHONPYCACHEPREFIX=../generated/backend/pycache
