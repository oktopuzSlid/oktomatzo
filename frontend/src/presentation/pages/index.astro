---
import Base from '../layouts/Base.astro'
---

<Base title="Oktomatzo Host" description="A platform hosting interactive projects and experiments">
  <section class="page-section" style="padding-top:40px;">
    <div class="container" style="display:grid;grid-template-columns:1fr 1fr;gap:48px;max-width:900px;align-items:start;">
      <div>
        <h1 style="font-size:2.5rem;font-weight:700;letter-spacing:-.04em;line-height:1.05;">
          Oktomatzo <span class="text-accent">Host</span>
        </h1>
        <p style="margin-top:16px;color:var(--text-secondary);line-height:1.7;">
          A platform for interactive projects — 3D visualizers, tools, and experiments.
          Sign in to save your work, or browse the projects.
        </p>
        <div style="display:flex;flex-direction:column;gap:8px;margin-top:28px;">
          <a href="/projects/" class="btn btn-primary" style="justify-content:center;">Browse Projects</a>
          <a href="/about/" class="btn btn-outline" style="justify-content:center;">About</a>
          <a href="/docs.html" class="btn btn-outline" style="justify-content:center;">Documentation</a>
        </div>
      </div>
      <div>
        <div style="display:flex;gap:0;margin-bottom:20px;border:1px solid var(--border);border-radius:8px;overflow:hidden;">
          <button id="tab-login" style="flex:1;padding:12px;background:var(--accent-subtle);color:var(--accent);border:none;cursor:pointer;font-family:inherit;font-size:.9rem;font-weight:500;">Log In</button>
          <button id="tab-signup" style="flex:1;padding:12px;background:transparent;color:var(--text-muted);border:none;cursor:pointer;font-family:inherit;font-size:.9rem;">Sign Up</button>
        </div>
        <form id="auth-form" novalidate style="display:flex;flex-direction:column;gap:14px;">
          <div id="name-field" style="display:none;flex-direction:column;gap:6px;">
            <label for="name" style="font-size:.85rem;color:var(--text-muted);">Name</label>
            <input type="text" id="name" style="padding:11px 16px;border-radius:8px;border:1px solid var(--border);background:var(--bg-card);color:var(--text);font-family:inherit;font-size:.9rem;">
          </div>
          <div style="display:flex;flex-direction:column;gap:6px;">
            <label for="email" style="font-size:.85rem;color:var(--text-muted);">Email</label>
            <input type="email" id="email" required style="padding:11px 16px;border-radius:8px;border:1px solid var(--border);background:var(--bg-card);color:var(--text);font-family:inherit;font-size:.9rem;">
          </div>
          <div style="display:flex;flex-direction:column;gap:6px;">
            <label for="password" style="font-size:.85rem;color:var(--text-muted);">Password</label>
            <input type="password" id="password" required minlength="8" style="padding:11px 16px;border-radius:8px;border:1px solid var(--border);background:var(--bg-card);color:var(--text);font-family:inherit;font-size:.9rem;">
          </div>
          <button type="submit" class="btn btn-primary" style="width:100%;margin-top:4px;">Log In</button>
        </form>
        <div id="auth-message" style="margin-top:14px;padding:12px;border-radius:8px;display:none;"></div>
        <div id="logged-in" style="display:none;margin-top:20px;text-align:center;">
          <div style="font-size:2.5rem;margin-bottom:12px;">&#10003;</div>
          <p style="color:var(--text-muted);">Logged in as <strong id="display-name" style="color:var(--text);"></strong></p>
          <button id="logout-btn" class="btn btn-outline" style="margin-top:14px;">Log Out</button>
        </div>
      </div>
    </div>
  </section>
</Base>

<script src="/js/login.js" defer></script>
