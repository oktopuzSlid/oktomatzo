HOST=0.0.0.0
PORT=8001
STORAGE_PATH=./storage
# CORS: in production (Render), both frontend and API are same origin.
# In development, allow the Astro dev server to call the Python backend.
CORS_ORIGINS=http://localhost:4321,http://localhost:8001
# IMPORTANT: Change this to a random secret before deploying to production.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key-in-production
